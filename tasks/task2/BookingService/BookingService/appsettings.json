{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    },
    "Endpoints": {
      "Grpc": {
        "Url": "http://*:9090"
      }
    },
    "ConnectionStrings": {
      "PostgreSQL": "Host=bookingservice-db;Port=5433;Database=hotelio;Username=hotelio;Password=hotelio"
    },
    "BookingSettings": {
      "MaxDiscountPercent": 50,
      "DefaultCurrency": "RUB"
    },
    "Kafka": {
      "BootstrapServers": "localhost:9092"
    }
  }
}
